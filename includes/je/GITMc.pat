// GITMc Pattern

import je.socket;

namespace auto je {

	struct GITMc {
		u8     type;
		u8     equip;
		u8     eqslot;
		Socket Hea;
		u8     hHai;
		u8     hBea;
		u8     hMus;
		u8     hEye;
		u8     hPon;
		u8     hVan;
		Socket Eye;
		Socket Bod;
		Socket Bac;
		Socket Han;
		Socket Fee;
		Socket Sho;
		Socket Van;
		Socket IHS;
		u32    reload;
	};

}
